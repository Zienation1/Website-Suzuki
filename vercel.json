{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "BERANDA/**",
          "KATALOG/**",
          "ADMIN/**",
          "BANDING MOTOR/**",
          "BERANDA ADMIN/**",
          "DATA/**",
          "EDIT BERANDA ADMIN/**",
          "HASIL KALKULATOR/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
