{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/$",
      "status": 302,
      "headers": { "Location": "/BERANDA/index_beranda.html" }
    }
  ]
}
